{
  "$schema": "./node_modules/@angular-devkit/schematics/collection-schema.json",
  "schematics": {
    "page": {
      "description": "Generate a page component",
      "factory": "./dist/components/page/index#page",
      "schema": "./src/components/page/schema.json"
    },
    "section": {
      "description": "Generate a section component",
      "factory": "./dist/components/section/index#section",
      "schema": "./src/components/section/schema.json"
    },
    "card": {
      "description": "Generate a card component",
      "factory": "./dist/components/card/index#card",
      "schema": "./src/components/card/schema.json"
    },
    "tile": {
      "description": "Generate a tile component",
      "factory": "./dist/components/tile/index#tile",
      "schema": "./src/components/tile/schema.json"
    },
    "ng-add": {
      "description": "Setup generator-angular",
      "factory": "./dist/core/ng-add/index#ngAdd"
    },
    "style": {
      "description": "Generate a global style",
      "factory": "./dist/others/style/index#style",
      "schema": "./src/others/style/schema.json"
    },
    "page-section": {
      "description": "Generate a section component into a page component",
      "factory": "./dist/components/page/section/index#pageSection",
      "schema": "./src/components/page/section/schema.json"
    }
  }
}
