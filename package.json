{
  "name": "@chinjto/generator-angular",
  "version": "1.2.0",
  "description": "Custom Angular schematics for opinionated project structures.",
  "schematics": "./collection.json",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc && cp -R src/templates dist/templates",
    "rebuild": "npm run clean && npm run build",
    "sandbox": "./.scripts/sandbox-angular.sh",
    "sandbox:idea": "./.scripts/sandbox-angular.sh --idea",
    "sandbox:clean": "rm -rf ~/.chinjto/gen-angular-*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chinjto/generator-angular.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "src/**/*.json",
    "collection.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [],
  "author": "Chinjto <contact@chinto.fr> (https://www.chinto.fr)",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/chinjto/generator-angular/issues"
  },
  "homepage": "https://github.com/chinjto/generator-angular#readme",
  "dependencies": {
    "@angular-devkit/core": "^21.2.16",
    "@angular-devkit/schematics": "^21.2.16",
    "ansi-colors": "^4.1.3",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
