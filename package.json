  },
  "homepage": "https://github.com/chinjto/generator-angular#readme",
  "dependencies": {
    "@angular-devkit/core": "^21.2.16",
    "@angular-devkit/schematics": "^21.2.16"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
