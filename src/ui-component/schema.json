{
  "$schema": "http://json-schema.org/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Component name",
      "$default": {
        "$source": "argv",
        "index": 0
      }
    },
    "type": {
      "type": "string",
      "description": "UI component type",
      "enum": ["page", "section", "card", "tile"]
    }
  },
  "required": ["name", "type"]
}
